<style>
  body {
    font-family: Arial, sans-serif;
    margin: 0;
    padding: 20px;
    background-color: #f5f5f5;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    background-color: white;
    padding: 30px;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .header-section {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
  }

  .header-section h2 {
    margin: 0;
    color: #333;
    font-size: 24px;
  }

  .add-btn {
    padding: 12px 25px;
    background-color: #28a745;
    color: white;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .add-btn:hover {
    background-color: #218838;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 20px;
  }

  table thead {
    background-color: #007bff;
    color: white;
  }

  table th {
    padding: 15px;
    text-align: center;
    font-weight: 600;
    border: 1px solid #dee2e6;
  }

  table td {
    padding: 12px 15px;
    border: 1px solid #dee2e6;
    text-align: center;
  }

  table tbody tr:nth-child(even) {
    background-color: #f9f9f9;
  }

  table tbody tr:hover {
    background-color: #f0f0f0;
  }

  .action-links a {
    margin: 0 8px;
    padding: 6px 12px;
    border-radius: 3px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .action-links a:first-child {
    background-color: #ffc107;
    color: #333;
  }

  .action-links a:first-child:hover {
    background-color: #e0a800;
    color: white;
  }

  .action-links a:last-child {
    background-color: #dc3545;
    color: white;
  }

  .action-links a:last-child:hover {
    background-color: #c82333;
  }

  .empty-message {
    text-align: center;
    padding: 40px;
    color: #999;
    font-size: 16px;
  }
</style>

<div class="container">
  <div class="header-section">
    <h2>Danh Sách Người Dùng</h2>
    <a href="/crud" class="add-btn">Add New User</a>
  </div>

  <% if (datalist && datalist.length > 0) { %>
    <table>
      <thead>
        <tr>
          <th>Email</th>
          <th>First Name</th>
          <th>Last Name</th>
          <th>Address</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% for(let i=0; i < datalist.length; i++) { %>
        <tr>
          <td><%= datalist[i].email %></td>
          <td><%= datalist[i].firstName %></td>
          <td><%= datalist[i].lastName %></td>
          <td><%= datalist[i].address %></td>
          <td class="action-links">
            <a href="/edit-crud?id=<%= datalist[i]._id %>">Edit</a>
            <a href="/delete-crud?id=<%= datalist[i]._id %>">Delete</a>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  <% } else { %>
    <div class="empty-message">
      <p>Không có người dùng nào. <a href="/crud" class="add-btn">Thêm người dùng mới</a></p>
    </div>
  <% } %>
</div>